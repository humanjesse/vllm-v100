# vllm-v100: V100 (SM70) inference image -- built from source
#
# Unlike docker/Dockerfile.sm70-wheel (which installs 1Cat's prebuilt v0.0.2
# wheel and overlays a handful of patched .py files), this Dockerfile compiles
# this fork's *own* wheels from source for SM70. That keeps the image in
# lockstep with the repo's Python AND CUDA patches -- the vendored TurboMind
# SM70 AWQ GEMM (csrc/quantization/awq/*sm70*, lmdeploy/src/turbomind), the
# GGUF csrc fp16 clamps, and the flash_attn_v100 HDIM templates all live in
# compiled code and cannot be delivered by copying .py files over a prebuilt
# wheel.
#
# Build (context must be the repo root so the builder can see csrc/, lmdeploy/,
# flash-attention-v100/):
#   docker build -f docker/Dockerfile.v100 -t vllm-v100:latest .
#
# Override the build parallelism if the builder host is memory-constrained:
#   docker build -f docker/Dockerfile.v100 --build-arg MAX_JOBS=16 ...

# ---------- Builder: compile vllm + flash_attn_v100 wheels for SM70 ----------
ARG CUDA_VERSION=12.8.1
FROM nvidia/cuda:${CUDA_VERSION}-devel-ubuntu24.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        python3.12 python3.12-dev python3.12-venv \
        python3-pip git ca-certificates build-essential \
    && rm -rf /var/lib/apt/lists/*

# Isolated venv so the wheels link against exactly this torch.
RUN python3.12 -m venv /opt/venv
ENV PATH=/opt/venv/bin:/usr/local/cuda/bin:$PATH
ENV CUDA_HOME=/usr/local/cuda

ARG TORCH_VERSION=2.9.1
ARG TORCHVISION_VERSION=0.24.1
ARG TORCHAUDIO_VERSION=2.9.1
RUN python -m pip install --upgrade pip setuptools wheel \
    && python -m pip install \
        torch==${TORCH_VERSION} \
        torchvision==${TORCHVISION_VERSION} \
        torchaudio==${TORCHAUDIO_VERSION} \
    && python -m pip install "cmake>=3.26,<4" ninja "setuptools-scm>=8" \
        "packaging>=24.2" jinja2 regex grpcio-tools build

# Only SM70 (V100). NVCC_THREADS x MAX_JOBS should fit the builder's RAM.
ENV TORCH_CUDA_ARCH_LIST="7.0" \
    VLLM_TARGET_DEVICE=cuda \
    NVCC_THREADS=4
ARG MAX_JOBS=32
ENV MAX_JOBS=${MAX_JOBS}

WORKDIR /src
COPY . /src

# Build both wheels (no build isolation -> reuse the torch installed above).
RUN python -m pip wheel . --no-build-isolation --no-deps -w /wheels \
    && python -m pip wheel ./flash-attention-v100 --no-build-isolation --no-deps -w /wheels \
    && ls -la /wheels

# ---------- Runtime: slim image, torch from pip (bundles cu128 libs) ----------
FROM python:3.12-slim-trixie AS runtime

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PYTHONUNBUFFERED=1 \
    HF_HOME=/root/.cache/huggingface \
    VLLM_NO_USAGE_STATS=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash ca-certificates curl libgl1 libglib2.0-0 libgomp1 tini \
    && rm -rf /var/lib/apt/lists/*

ARG TORCH_VERSION=2.9.1
ARG TORCHVISION_VERSION=0.24.1
ARG TORCHAUDIO_VERSION=2.9.1
RUN python -m pip install --upgrade pip \
    && python -m pip install \
        torch==${TORCH_VERSION} \
        torchvision==${TORCHVISION_VERSION} \
        torchaudio==${TORCHAUDIO_VERSION}

# Install the wheels we just built. vllm's runtime deps resolve from PyPI.
COPY --from=builder /wheels /wheels
RUN python -m pip install /wheels/vllm-*.whl \
    && python -m pip install --no-deps /wheels/flash_attn_v100-*.whl \
    && rm -rf /wheels

COPY docker/entrypoint.sm70.sh /usr/local/bin/entrypoint.sm70.sh
RUN chmod +x /usr/local/bin/entrypoint.sm70.sh

WORKDIR /workspace
EXPOSE 8000

ENTRYPOINT ["tini", "--", "/usr/local/bin/entrypoint.sm70.sh"]
CMD []
